# ── Dark Souls III Companion — Environment Variables ──
# Copy this file to `.env` (local dev) or set these in your Vercel project settings.
# The site does NOT use a database at runtime, but Prisma needs a value at
# build time to generate its client. Any placeholder works.

DATABASE_URL=file:./dev.db

# (Optional) NextAuth — only if you later add authentication
# NEXTAUTH_SECRET=replace-with-a-long-random-string
# NEXTAUTH_URL=http://localhost:3000
