# ── Dependencies ──
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ──
/coverage

# ── Next.js ──
/.next/
/out/

# ── Production ──
/build

# ── Database (SQLite, local only) ──
/db/
*.db
*.db-journal

# ── Misc ──
.DS_Store
*.pem
Thumbs.db

# ── Debug logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bun-debug.log*
*.log
dev.log
server.log

# ── Env files (keep .env.example tracked, ignore real secrets) ──
.env
.env.local
.env.development
.env.production
!.env.example

# ── Vercel ──
.vercel

# ── TypeScript ──
*.tsbuildinfo
next-env.d.ts

# ── Editor / OS ──
.vscode/
.idea/
local-*
.claude
.z-ai-config
prompt

# ── Sandbox-only artifacts (never commit) ──
/skills/
/examples/
/mini-services/
